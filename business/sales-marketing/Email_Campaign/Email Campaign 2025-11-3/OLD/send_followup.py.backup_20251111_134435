        return
    
    # Load prospect data for first names
    print("\n📋 Loading prospect lists for first names...")
    prospects_by_vertical = {}
    
    if config.TEST_MODE:
        vertical = config.TEST_VERTICAL
        df = load_prospects(vertical)
        if not df.empty:
            prospects_by_vertical[vertical] = df
            print(f"   ✓ {config.VERTICALS[vertical]['name']}: {len(df)} prospects")
    else:
        for vertical in config.ACTIVE_VERTICALS:
            df = load_prospects(vertical)
            if not df.empty:
                prospects_by_vertical[vertical] = df
                print(f"   ✓ {config.VERTICALS[vertical]['name']}: {len(df)} prospects")
    
    # Display candidates by vertical
    print("\n📊 Follow-up candidates by vertical:")
    for vertical in config.VERTICALS.keys():
        if vertical in followup_candidates:
            count = len(followup_candidates[vertical])
            print(f"   ✓ {config.VERTICALS[vertical]['name']}: {count} candidates")

    # Display email statistics (all-time, last 24h, this week)
    all_time_count, last_24h_count = display_email_statistics()

    print("💡 NOTE: Daily limit is based on last 24 hours (rolling window).")
    print("   The all-time count is only for tracking follow-up progress.\n")

    # Main continuous loop
    while not interrupted:
        # In test mode, skip business hours and daily limit checks
        if config.TEST_MODE:
            sent_count = send_batch(prospects_by_vertical, followup_candidates, 1)
            print("\n🧪 Test mode complete. Exiting.")
            break
        
        # Check business hours
        if not is_business_hours():
            next_window, time_str = calculate_next_send_window()
            
            if get_current_time_est().weekday() >= 5:
                display_status_box("WEEKEND - Waiting for Monday", next_window, time_str)
            elif get_current_time_est().hour < config.BUSINESS_HOURS_START:
                display_status_box("BEFORE BUSINESS HOURS - Waiting", next_window, time_str)
            else:
                display_status_box("AFTER BUSINESS HOURS - Waiting for tomorrow", next_window, time_str)
            
            for i in range(15):
                if interrupted:
                    break
                time.sleep(60)
            continue
        
        # Check daily limit
        emails_last_24h = get_emails_sent_last_24h()
        daily_limit_remaining = config.TOTAL_DAILY_LIMIT - emails_last_24h
        
        if daily_limit_remaining <= 0:
            print(f"\n📊 Daily limit reached ({emails_last_24h}/{config.TOTAL_DAILY_LIMIT})")
            next_window, time_str = calculate_next_send_window()
            display_status_box("DAILY LIMIT REACHED - Waiting for next window", next_window, time_str)
            
            for i in range(15):
                if interrupted:
                    break
                time.sleep(60)
            continue
        
        # Ready to send!
        print(f"\n✅ Business hours detected (Mon-Fri, 9am-3pm EST)")
        print(f"✅ Daily quota: {emails_last_24h}/{config.TOTAL_DAILY_LIMIT} sent in last 24h")
        print(f"✅ Remaining today: {daily_limit_remaining} emails\n")

        # Reload follow-up candidates from response tracker to catch any updates
        # (prevents duplicates when restarting script or running multiple instances)
        print("📋 Reloading follow-up candidates from tracker (deduplication)...")
        followup_candidates = load_followup_candidates()
        total_followup_needs = sum(len(followup_candidates.get(v, [])) for v in config.ACTIVE_VERTICALS)

        if not followup_candidates or total_followup_needs == 0:
            print("   ℹ️  No more follow-up candidates available.")
            print("   Waiting for new candidates or next send window...\n")
            # Sleep for 15 minutes, then check again
            for i in range(15):
                if interrupted:
                    break
                time.sleep(60)
            continue

        print(f"   ✓ Loaded {total_followup_needs} follow-up candidates\n")

        # Calculate total followup needs (from all active verticals)
        total_followup_needs = sum(len(followup_candidates.get(v, [])) for v in config.ACTIVE_VERTICALS)

        # Report needs and get allocation from coordination system
        print("📊 Coordinating with initial outreach script...")
        print(f"   Follow-up needs: {total_followup_needs} candidates ready")
        allocated_capacity = coordination.report_needs_and_allocate('followup', total_followup_needs)
        coordination.mark_script_running('followup')

        # Display coordination summary (central status view)
        coordination.display_allocation_summary()

        # Get how many we can still send (remaining capacity)
        remaining_capacity = coordination.get_remaining_capacity('followup')

        # Enhanced daily allocation display
        print("\n╔════════════════════════════════════════════════════════════╗")
        print("║  TODAY'S ALLOCATION (FOLLOW-UP)                            ║")
        print("╠════════════════════════════════════════════════════════════╣")
        print(f"║  Total allocated today:           {allocated_capacity:<24} ║")
        print(f"║  Already sent today:              {allocated_capacity - remaining_capacity:<24} ║")
        print(f"║  Remaining to send today:         {remaining_capacity:<24} ║")
        print("╚════════════════════════════════════════════════════════════╝\n")

        # If we've already sent our allocation, we're done
        if remaining_capacity <= 0:
            print(f"\n✅ Allocation complete! Already sent {allocated_capacity}/{allocated_capacity} emails.")
            print("   Waiting for next send window...\n")
            # Sleep for 15 minutes, then check again
            for i in range(15):
                if interrupted:
                    break
                time.sleep(60)
            continue

        # Send batch (only what we have remaining)
        effective_capacity = min(remaining_capacity, daily_limit_remaining)
        print(f"✅ Will send: {effective_capacity} emails\n")

        sent_count = send_batch(prospects_by_vertical, followup_candidates, effective_capacity)

        # Coordination is updated real-time in send_batch, but verify here
        if sent_count > 0:
            pass  # Already updated in send_batch
        
        # Display summary
        if sent_count > 0:
            display_session_summary(sent_count, config.ACTIVE_VERTICALS)
        
        # Wait and check again
        print("\n⏸️  Batch complete. Checking conditions again in 15 minutes...")
        for i in range(15):
            if interrupted:
                break
            time.sleep(60)
    
    # Graceful shutdown
    coordination.mark_script_stopped('followup')
    print(f"\n\n✅ Stopped. Sent {emails_sent_this_session} follow-ups this session. All progress saved.")
    print("💡 Run script again to pick up where you left off.\n")

if __name__ == "__main__":
    try:
        main()
    except Exception as e:
        print(f"\n❌ Fatal error: {e}")
        import traceback
        traceback.print_exc()
        sys.exit(1)
